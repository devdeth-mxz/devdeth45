<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Photo Gallery</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #f4f4f4;
        }

        h1 {
            text-align: center;
            padding: 20px;
        }

        /* Grid Gallery */
        .gallery {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            padding: 20px;
        }

        .gallery img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 10px;
            transition: transform 0.3s;
        }

        .gallery img:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body>

    <h1>My Photo Gallery</h1>

    <div class="gallery">
        <img src="https://via.placeholder.com/300?text=Image+1" alt="Image 1">
        <img src="https://via.placeholder.com/300?text=Image+2" alt="Image 2">
        <img src="https://via.placeholder.com/300?text=Image+3" alt="Image 3">
        <img src="https://via.placeholder.com/300?text=Image+4" alt="Image 4">
        <img src="https://via.placeholder.com/300?text=Image+5" alt="Image 5">
        <img src="https://via.placeholder.com/300?text=Image+6" alt="Image 6">
    </div>

</body>
</html>
